## 6. scripts/run_pipeline.py

路径：

```text
pledgebox_order_skill/scripts/run_pipeline.py
```

职责：

```text
串联完整流程：
请求 API → 保存原始数据 → 清洗数据 → 保存结果
```

代码：

```python
import argparse
import json
import os
import sys

from fetch_orders import fetch_orders
from clean_orders import clean_orders


def ensure_output_dir(output_dir: str):
    """
    Ensure output directory exists.
    """
    os.makedirs(output_dir, exist_ok=True)


def save_json(data, path: str):
    """
    Save data as JSON file.
    """
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)


def extract_order_list(raw_response):
    """
    Extract order list from PledgeBox API response.

    Different APIs may return:
    1. A list directly
    2. A dict with data as list
    3. A dict with data as single object

    This function normalizes them into a list.
    """

    if isinstance(raw_response, list):
        return raw_response

    if isinstance(raw_response, dict):
        data = raw_response.get("data")

        if isinstance(data, list):
            return data

        if isinstance(data, dict):
            return [data]

        # Some APIs may return orders directly in the root object.
        if "pbid" in raw_response:
            return [raw_response]

    return []


def main():
    parser = argparse.ArgumentParser(
        description="Fetch and clean PledgeBox order data."
    )

    parser.add_argument("--api_token", required=True, help="PledgeBox API token")
    parser.add_argument("--project_id", required=True, type=int, help="PledgeBox project ID")
    parser.add_argument("--page", default=1, type=int, help="Page number")
    parser.add_argument("--is_completed", default=None, help="1 for completed orders")
    parser.add_argument("--order_status", default=None, help="unlock / lock / shipped / refunded")
    parser.add_argument("--pb_id", default=None, help="Specific PledgeBox ID")
    parser.add_argument("--email", default=None, help="Specific backer email")
    parser.add_argument("--output_dir", default="output", help="Output directory")

    args = parser.parse_args()

    ensure_output_dir(args.output_dir)

    try:
        raw_response = fetch_orders(
            api_token=args.api_token,
            project_id=args.project_id,
            page=args.page,
            is_completed=args.is_completed,
            order_status=args.order_status,
            pb_id=args.pb_id,
            email=args.email,
        )
    except Exception as e:
        print(f"[ERROR] Failed to fetch orders: {e}")
        sys.exit(1)

    raw_output_path = os.path.join(args.output_dir, "raw_orders.json")
    save_json(raw_response, raw_output_path)

    raw_orders = extract_order_list(raw_response)

    if not raw_orders:
        print("[WARNING] No orders found in API response.")

    cleaned_orders, errors = clean_orders(raw_orders)

    cleaned_output_path = os.path.join(args.output_dir, "cleaned_orders.json")
    error_output_path = os.path.join(args.output_dir, "error_log.json")

    save_json(cleaned_orders, cleaned_output_path)
    save_json(errors, error_output_path)

    print("[DONE] PledgeBox order cleaning finished.")
    print(f"Raw data saved to: {raw_output_path}")
    print(f"Cleaned data saved to: {cleaned_output_path}")
    print(f"Error log saved to: {error_output_path}")
    print(f"Total raw orders: {len(raw_orders)}")
    print(f"Total cleaned orders: {len(cleaned_orders)}")
    print(f"Total errors: {len(errors)}")


if __name__ == "__main__":
    main()
```

